{
  "manifest_version": 3,
  "name": "Life Dashboard — Time Tracker",
  "version": "1.0.0",
  "description": "Silently tracks browser time and syncs to Life Dashboard. Alerts when daily budgets are reached.",
  "permissions": [
    "tabs",
    "storage",
    "idle",
    "alarms"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
